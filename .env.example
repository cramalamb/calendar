# Copy to .env and customize for your environment.
GCAL_CALENDAR_ID=primary
DEFAULT_DURATION_MIN=60
DEFAULT_ADD_GOOGLE_MEET=false
DEFAULT_TIMEZONE=America/Indiana/Indianapolis

CAL_API_BASE=http://127.0.0.1:8010
LOG_LEVEL=info
CAL_API_KEY=change-me-to-a-long-random-string

# Optional: enable the ai_cli helper
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
